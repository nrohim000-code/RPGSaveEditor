{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window with broad but secure fs access",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "updater:default",
    "dialog:allow-open",
    "dialog:default",
    "fs:default",
    "fs:allow-app-write",
    "fs:allow-app-read",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "**" }

      ],
      "deny": [                          
        { "path": "$HOME/.config/**" },  
        { "path": "$APPDATA/EBWebView/**" }, 
        { "path": "$HOME/.ssh/**" }      
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",  
      "allow": [
        { "path": "*.json" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "**" }
      ]
    }
  ]
}