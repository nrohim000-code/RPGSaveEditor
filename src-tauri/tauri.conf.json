{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "RPG Save Editor",
  "version": "1.2.0",
  "identifier": "com.tauri.build",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RPG Save Editor",
        "width": 1000,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icons8-edit-32.png",
      "icons/icons8-edit-64.png",
      "icons/icons8-edit-128.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "windows": {
        "installMode": "passive"
      },
      "active": true,
      "endpoints": ["https://raw.githubusercontent.com/truongthang2211/RPGSaveEditor/main/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE3ODgzRjY3QjU5NUZCQgpSV1M3WDFsNzlvTjRBZGJjOXRDSFhoMC9xWHN6RmE5WVFkK1FITk5sMjEzUEJ4Q3hDUEp1bE9nQgo="
    }
  }

}
